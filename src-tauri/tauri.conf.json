{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "targoo advisor engine",
  "version": "0.1.0",
  "identifier": "com.targoo.advisor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "targoo advisor engine",
        "width": 1200,
        "height": 800,
        "webviewInstallMode": {
          "type": "downloadBootstrapper",
          "silent": true
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Targoo Software",
    "copyright": "2026 Targoo Software",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "German"],
        "displayLanguageSelector": false
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
