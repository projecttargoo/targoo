{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "targoo",
  "version": "0.1.0",
  "identifier": "com.targoo.advisor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Targoo",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "publisher": "Targoo Software",
    "copyright": "2025 Targoo Software",
    "shortDescription": "AI-powered ESG Advisor for CSRD compliance",
    "longDescription": "Targoo is an offline-first ESG advisor that helps consultants automate CSRD reporting, gap analysis and Scope 1/2/3 calculations.",
    "category": "BusinessApplication",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English",
          "German"
        ],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.png",
        "headerImage": "icons/icon.png",
        "sidebarImage": "icons/icon.png"
      },
      "wix": null,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
